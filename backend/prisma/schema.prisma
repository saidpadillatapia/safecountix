// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id         Int        @id @default(autoincrement())
  nombre     String
  subdominio String     @unique
  plan       String     @default("basico")
  activo     Boolean    @default(true)
  usuarios   Usuario[]
  empleados  Empleado[]
  evacuaciones HistorialEvacuacion[]
  alertas      Alerta[]
  incidencias  Incidencia[]
  visitantes   Visitante[]
}

model Usuario {
  id            Int     @id @default(autoincrement())
  empresaId     Int
  nombre        String
  email         String  @unique
  passwordHash  String
  rol           String  // "admin" | "seguridad" | "rh"
  empresa       Empresa @relation(fields: [empresaId], references: [id])
}

model Empleado {
  id                  Int        @id @default(autoincrement())
  empresaId           Int
  nombre              String
  numeroTarjeta       String     @unique
  turno               String     // "manana" | "tarde" | "noche"
  departamento        String
  tipo                String     // "empleado" | "brigadista" | "proveedor"
  especialidadBrigada String?    // "primeros_auxilios" | "evacuacion" | "comunicacion" | "busqueda"
  estadoActual        String     @default("fuera") // "dentro" | "fuera"
  activo              Boolean    @default(true)
  empresa             Empresa    @relation(fields: [empresaId], references: [id])
  registros           Registro[]

  @@index([empresaId, estadoActual, activo])
  @@index([empresaId, activo])
}

model Registro {
  id         Int      @id @default(autoincrement())
  empleadoId Int
  tipo       String   // "entrada" | "salida" | "salida_automatica"
  puerta     String   // "peatonal" | "vehicular"
  fechaHora  DateTime @default(now())
  empleado   Empleado @relation(fields: [empleadoId], references: [id])

  @@index([empleadoId])
  @@index([fechaHora])
}

model HistorialEvacuacion {
  id              Int      @id @default(autoincrement())
  empresaId       Int
  fechaInicio     DateTime
  fechaFin        DateTime
  duracionSegundos Int
  totalEnPlanta   Int      // personas en planta al iniciar
  totalEvacuados  Int      // personas marcadas como evacuadas
  brigadistas     Int      // brigadistas en planta durante la evacuación
  empresa         Empresa  @relation(fields: [empresaId], references: [id])
}

model Alerta {
  id          Int      @id @default(autoincrement())
  empresaId   Int
  tipo        String   // "evacuacion_pendiente" | "sobre_cupo" | "visitante_sin_salida" | "incidencia"
  mensaje     String
  nivel       String   @default("warning") // "info" | "warning" | "critical"
  leida       Boolean  @default(false)
  fechaCreada DateTime @default(now())
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
}

model Incidencia {
  id          Int      @id @default(autoincrement())
  empresaId   Int
  titulo      String
  descripcion String   @db.Text
  area        String
  nivel       String   // "baja" | "media" | "alta" | "critica"
  estado      String   @default("abierta") // "abierta" | "en_proceso" | "resuelta"
  fechaCreada DateTime @default(now())
  fechaResuelta DateTime?
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
}

model Visitante {
  id          Int      @id @default(autoincrement())
  empresaId   Int
  nombre      String
  empresaOrigen String
  motivo      String
  acceso      String   // puerta de acceso
  fechaEntrada DateTime @default(now())
  fechaSalida  DateTime?
  estado      String   @default("dentro") // "dentro" | "fuera"
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
}
